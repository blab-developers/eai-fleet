{
  "name": "fleet-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "yarn@4.0.0",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "gen:backend-api": "node scripts/gen-backend-api.mjs",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test:unit": "vitest run --project unit && vitest run --project browser",
    "test:logic": "vitest run --project unit",
    "test:components": "vitest run --project browser",
    "test:e2e": "vite build && playwright test",
    "mock:backend": "python scripts/mock-backend.py"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.98.1",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^25.9.2",
    "@vitest/browser": "5.0.0-beta.5",
    "@vitest/browser-playwright": "5.0.0-beta.5",
    "carbon-preprocess-svelte": "^0.11.31",
    "sass": "^1.86.3",
    "svelte": "^5.56.2",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "5.0.0-beta.5",
    "vitest-browser-svelte": "^2.1.1"
  },
  "dependencies": {
    "carbon-components-svelte": "^1.0.0-next.1",
    "carbon-icons-svelte": "^12.13.0"
  }
}
