# Frontend dev config. Copy to .env for `yarn dev`.

# Server-side proxy target — where hooks.server.ts forwards /api/* (PRIVATE; never
# exposed to the browser). Point at a running backend (apps/backend on :8088).
EAI_FLEET_BACKEND_URL=http://localhost:8088

# Central Grafana base for the per-device "History" link (PUBLIC; browser-readable).
# Deep-link to the fleet dashboard; the device_id is appended as ?var-device=...
EAI_FLEET_FRONTEND_GRAFANA_URL=https://metrics.endoscopeai.com/d/eai-fleet/eai-fleet
